const mongoose = require("mongoose");

const seasonStandingsSchema = new mongoose.Schema({
    season: {
        type: Number,
    }, 
    user: {
        type: mongoose.Schema.Types.ObjectId,
        ref: 'User',
        required: true
    },
    totalPoints: {
        type: Number,
        default: 0
    },
    racePoints: [{
        race: {
            type: mongoose.Schema.Types.ObjectId, ref:'Race'},
            points: {
                type: Number,
                default: 0 }
    }]
    }, { timestamps: true });

seasonStandingsSchema.index({ season: 1, totalPoints: -1 });
module.exports = mongoose.model('SeasonStandings', seasonStandingsSchema);